#!/bin/bash
# Ultra-discrete startup (for .bashrc or manual use)
# Starts container only if not already running
# No output unless there's an error

CONTAINER_NAME="brian"
PORT=1234

if command -v podman &> /dev/null; then
    RUNTIME="podman"
elif command -v docker &> /dev/null; then
    RUNTIME="docker"
else
    exit 0
fi

# Start if not running
if ! $RUNTIME ps --format "{{.Names}}" 2>/dev/null | grep -q "^${CONTAINER_NAME}$"; then
    cd ~/brianhsu-portfolio 2>/dev/null || cd /Users/brianhsu/brianhsu-portfolio 2>/dev/null || exit 0
    
    # Build if needed
    if ! $RUNTIME images --format "{{.Repository}}" 2>/dev/null | grep -q "^${CONTAINER_NAME}$"; then
        $RUNTIME build -t $CONTAINER_NAME -q . > /dev/null 2>&1
    fi
    
    # Start silently
    $RUNTIME run -d \
        --name $CONTAINER_NAME \
        --restart unless-stopped \
        -p 127.0.0.1:$PORT:3000 \
        -v "$(pwd)/src:/app/src:ro" \
        -v "$(pwd)/public:/app/public:ro" \
        $CONTAINER_NAME > /dev/null 2>&1
fi
